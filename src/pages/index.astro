---
import "../styles/global.css";

const creations = [
  { title: "Deep earth", imageMobile: "image-deep-earth.jpg", imageDesktop: "image-deep-earth.jpg" },
  { title: "Night arcade", imageMobile: "image-night-arcade.jpg", imageDesktop: "image-night-arcade.jpg" },
  { title: "Soccer team VR", imageMobile: "image-soccer-team.jpg", imageDesktop: "image-soccer-team.jpg" },
  { title: "The grid", imageMobile: "image-grid.jpg", imageDesktop: "image-grid.jpg" },
  { title: "From up above VR", imageMobile: "image-from-above.jpg", imageDesktop: "image-from-above.jpg" },
  { title: "Pocket borealis", imageMobile: "image-pocket-borealis.jpg", imageDesktop: "image-pocket-borealis.jpg" },
  { title: "The curiosity", imageMobile: "image-curiosity.jpg", imageDesktop: "image-curiosity.jpg" },
  { title: "Make it fisheye", imageMobile: "image-fisheye.jpg", imageDesktop: "image-fisheye.jpg" }
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Loopstudios landing page</title>
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Alata&family=Josefin+Sans:wght@300&display=swap" rel="stylesheet">
	</head>
	<body class="bg-primary-white">
		<!-- Header / Navigation -->
		<header class="absolute top-0 left-0 w-full z-50 p-6 md:px-40 md:py-16 flex items-center justify-between">
			<img src="/images/logo.svg" alt="Loopstudios Logo" class="w-36 md:w-48 relative z-50" />
			
			<!-- Mobile Menu Toggle -->
			<button id="menu-toggle" class="md:hidden relative z-50">
				<img id="menu-icon" src="/images/icon-hamburger.svg" alt="Open Menu" />
			</button>
			
			<!-- Desktop Navigation -->
			<nav class="hidden md:flex space-x-8 text-primary-white font-alata">
				{["About", "Careers", "Events", "Products", "Support"].map(item => (
					<a href="#" class="relative group pb-2">
						{item}
						<span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-primary-white transition-all duration-300 group-hover:w-full"></span>
					</a>
				))}
			</nav>
		</header>

		<!-- Mobile Menu Overlay -->
		<div id="mobile-menu" class="fixed inset-0 bg-primary-black text-primary-white px-6 py-48 z-40 hidden flex-col justify-center space-y-6 uppercase font-josefin text-3xl font-light tracking-widest">
			{["About", "Careers", "Events", "Products", "Support"].map(item => (
				<a href="#" class="w-max relative group">
					{item}
					<span class="absolute bottom-[-8px] left-1/2 -translate-x-1/2 w-0 h-[2px] bg-primary-white transition-all duration-300 group-hover:w-full"></span>
				</a>
			))}
		</div>

		<!-- Hero Section -->
		<section class="min-h-screen relative flex items-center md:items-center px-6 md:px-40 pt-24 md:pt-0">
			<picture class="absolute inset-0 z-0">
				<source media="(min-width: 768px)" srcset="/images/desktop/image-hero.jpg" />
				<img src="/images/mobile/image-hero.jpg" alt="Hero background" class="w-full h-full object-cover brightness-75 md:brightness-100" />
			</picture>
			<!-- Dark overlay for hero to ensure text readability -->
			<div class="absolute inset-0 bg-primary-black/30 z-0 content-['']"></div>

			<div class="relative z-10 w-full">
				<h1 class="font-josefin text-white text-4xl leading-tight md:text-[72px] md:leading-none uppercase border-[3px] border-white p-6 md:p-10 max-w-sm md:max-w-2xl tracking-wide">
					Immersive<br/>experiences<br/>that<br class="md:hidden"/><span class="hidden md:inline"> </span>deliver
				</h1>
			</div>
		</section>

		<!-- About VR Section -->
		<section class="px-6 md:px-40 py-24 md:py-32 flex flex-col md:flex-row relative items-center">
			<img src="/images/mobile/image-interactive.jpg" alt="Interactive VR" class="md:hidden mb-12 sm:mb-16 w-full" />
			<img src="/images/desktop/image-interactive.jpg" alt="Interactive VR" class="hidden md:block md:w-[65%]" />
			
			<div class="bg-primary-white pt-12 text-center md:text-left md:absolute md:bottom-24 md:right-40 md:w-[50%] md:pt-24 md:pl-24">
				<h2 class="text-3xl md:text-5xl font-josefin uppercase mb-6 text-primary-black leading-none">The leader in<br class="hidden md:block"/> interactive VR</h2>
				<p class="text-neutral-dark-gray font-alata leading-relaxed text-[15px]">
					Founded in 2011, Loopstudios has been producing world-class virtual reality projects for some of the best companies around the globe. Our award-winning creations have transformed businesses through digital experiences that bind to their brand.
				</p>
			</div>
		</section>

		<!-- Our Creations Section -->
		<section class="px-6 md:px-40 pb-24 md:pb-32">
			<div class="flex flex-col md:flex-row justify-between items-center mb-12 md:mb-20">
				<h2 class="text-3xl md:text-4xl font-josefin uppercase text-primary-black text-center md:text-left mb-8 md:mb-0">Our creations</h2>
				<button class="hidden md:block uppercase tracking-widest border-2 border-primary-black px-12 py-3 hover:bg-primary-black hover:text-primary-white transition-colors duration-300 font-alata text-sm">See all</button>
			</div>

			<!-- Grid -->
			<div class="grid grid-cols-1 md:grid-cols-4 gap-6">
				{creations.map((item) => (
					<a href="#" class="relative group cursor-pointer overflow-hidden block w-full aspect-[2/1] md:aspect-[3/7]">
						<picture class="absolute inset-0 z-0">
							<source media="(min-width: 768px)" srcset={`/images/desktop/${item.imageDesktop}`} />
							<img src={`/images/mobile/${item.imageMobile}`} alt={item.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
						</picture>
						<!-- Default dark gradient -->
						<div class="absolute inset-0 bg-gradient-to-t from-primary-black/60 to-transparent z-10"></div>
						<!-- Hover white overlay -->
						<div class="absolute inset-0 bg-primary-white/0 group-hover:bg-primary-white/70 transition-colors duration-500 z-20"></div>
						
						<h3 class="absolute bottom-6 left-6 md:bottom-8 md:left-8 text-white text-2xl md:text-3xl font-josefin uppercase font-light w-32 md:w-40 group-hover:text-black z-30 transition-colors duration-500 leading-none">
							{item.title}
						</h3>
					</a>
				))}
			</div>

			<!-- Mobile See All Button -->
			<div class="mt-8 flex justify-center md:hidden w-full">
				<button class="uppercase tracking-widest border-2 border-primary-black px-10 py-3 hover:bg-primary-black hover:text-primary-white transition-colors duration-300 font-alata w-full text-base">See all</button>
			</div>
		</section>

		<!-- Footer -->
		<footer class="bg-primary-black py-12 md:py-16 px-6 md:px-40 text-center md:text-left mt-auto">
			<div class="flex flex-col md:flex-row justify-between items-center md:items-start space-y-12 md:space-y-0">
				
				<!-- Logo and Nav -->
				<div class="flex flex-col space-y-8">
					<img src="/images/logo.svg" alt="Loopstudios Logo" class="mx-auto md:mx-0 w-36 md:w-40" />
					<nav class="flex flex-col md:flex-row gap-6 md:gap-8 text-white font-alata">
						{["About", "Careers", "Events", "Products", "Support"].map(item => (
							<a href="#" class="relative group w-max mx-auto md:mx-0 pb-2">
								{item}
								<span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-white transition-all duration-300 group-hover:w-full"></span>
							</a>
						))}
					</nav>
				</div>
				
				<!-- Social and Copyright -->
				<div class="flex flex-col space-y-6 md:space-y-8 items-center md:items-end">
					<div class="flex space-x-5">
						<a href="#" class="group relative pb-2">
							<img src="/images/icon-facebook.svg" alt="Facebook" />
							<span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-primary-white transition-all duration-300 group-hover:w-full"></span>
						</a>
						<a href="#" class="group relative pb-2">
							<img src="/images/icon-twitter.svg" alt="Twitter" />
							<span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-primary-white transition-all duration-300 group-hover:w-full"></span>
						</a>
						<a href="#" class="group relative pb-2">
							<img src="/images/icon-pinterest.svg" alt="Pinterest" />
							<span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-primary-white transition-all duration-300 group-hover:w-full"></span>
						</a>
						<a href="#" class="group relative pb-2">
							<img src="/images/icon-instagram.svg" alt="Instagram" />
							<span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-primary-white transition-all duration-300 group-hover:w-full"></span>
						</a>
					</div>
					<p class="text-neutral-dark-gray text-[15px] font-alata">© 2021 Loopstudios. All rights reserved.</p>
				</div>
				
			</div>
		</footer>

		<!-- Script for Mobile Menu -->
		<script>
			const menuToggle = document.getElementById('menu-toggle');
			const mobileMenu = document.getElementById('mobile-menu');
			const menuIcon = document.getElementById('menu-icon') as HTMLImageElement;

			menuToggle?.addEventListener('click', () => {
				const isHidden = mobileMenu?.classList.contains('hidden');
				if (isHidden) {
					mobileMenu?.classList.remove('hidden');
					mobileMenu?.classList.add('flex');
					if (menuIcon) menuIcon.src = '/images/icon-close.svg';
					document.body.style.overflow = 'hidden'; // Prevent scrolling
				} else {
					mobileMenu?.classList.add('hidden');
					mobileMenu?.classList.remove('flex');
					if (menuIcon) menuIcon.src = '/images/icon-hamburger.svg';
					document.body.style.overflow = ''; // Restore scrolling
				}
			});
		</script>
	</body>
</html>
