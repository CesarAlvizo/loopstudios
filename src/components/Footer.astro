---

---

<footer
    class="bg-primary-black py-12 md:py-16 px-6 md:px-40 text-center md:text-left mt-auto"
>
    <div
        class="flex flex-col md:flex-row justify-between items-center md:items-start space-y-12 md:space-y-0"
    >
        <!-- Logo and Nav -->
        <div class="flex flex-col space-y-8">
            <img
                src="/images/logo.svg"
                alt="Loopstudios Logo"
                class="mx-auto md:mx-0 w-36 md:w-40"
            />
            <nav
                class="flex flex-col md:flex-row gap-6 md:gap-8 text-white font-alata"
            >
                {
                    ["About", "Careers", "Events", "Products", "Support"].map(
                        (item) => (
                            <a
                                href="#"
                                class="relative group w-max mx-auto md:mx-0 pb-2"
                            >
                                {item}
                                <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-white transition-all duration-300 group-hover:w-full" />
                            </a>
                        ),
                    )
                }
            </nav>
        </div>

        <div
            class="flex flex-col space-y-6 md:space-y-8 items-center md:items-end"
        >
            <div class="flex space-x-5">
                <a href="#" class="group relative pb-2">
                    <img src="/images/icon-facebook.svg" alt="Facebook" />
                    <span
                        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-primary-white transition-all duration-300 group-hover:w-full"
                    ></span>
                </a>
                <a href="#" class="group relative pb-2">
                    <img src="/images/icon-twitter.svg" alt="Twitter" />
                    <span
                        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-primary-white transition-all duration-300 group-hover:w-full"
                    ></span>
                </a>
                <a href="#" class="group relative pb-2">
                    <img src="/images/icon-pinterest.svg" alt="Pinterest" />
                    <span
                        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-primary-white transition-all duration-300 group-hover:w-full"
                    ></span>
                </a>
                <a href="#" class="group relative pb-2">
                    <img src="/images/icon-instagram.svg" alt="Instagram" />
                    <span
                        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-[2px] bg-primary-white transition-all duration-300 group-hover:w-full"
                    ></span>
                </a>
            </div>
            <p class="text-neutral-dark-gray text-[15px] font-alata">
                © 2021 Loopstudios. All rights reserved.
            </p>
        </div>
    </div>
</footer>
